containers: {
  web: {
    image: "python:3.12"

    build: {
      context: "."
    }

    ports: {
      publish: "8000:8000/http"
    }

    env: {
      DJANGO_SETTINGS_MODULE: "store.settings"
    }

    command: [
      "python",
      "manage.py",
      "runserver",
      "0.0.0.0:8000"
    ]
  }
}